# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Supabase S3-compatible storage
SUPABASE_S3_ACCESS_KEY_ID=your-s3-access-key-id
SUPABASE_S3_SECRET_ACCESS_KEY=your-s3-secret-access-key
SUPABASE_S3_REGION=eu-central-1
SUPABASE_S3_ENDPOINT=https://your-project-ref.storage.supabase.co/storage/v1/s3
SUPABASE_S3_BUCKET=rootsybucket

# Trefle API (plant data) — https://trefle.io  |  120 req/min free tier
TREFLE_API_TOKEN=your-trefle-api-token

# Apple WeatherKit REST API — https://developer.apple.com/weatherkit/
APPLE_TEAM_ID=YOUR_TEAM_ID
APPLE_KEY_ID=YOUR_KEY_ID
APPLE_SERVICE_ID=com.yourapp.weatherkit
# Path to your Apple .p8 private key file (or paste key contents below)
APPLE_PRIVATE_KEY_PATH=/path/to/AuthKey_XXXXXXXXXX.p8
# OR paste the key directly (used if path not set):
# APPLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----

# OpenRouter.ai — https://openrouter.ai
OPENROUTER_API_KEY=your-openrouter-api-key
# Model for chat: e.g. anthropic/claude-haiku-4-5, openai/gpt-4o-mini
OPENROUTER_CHAT_MODEL=anthropic/claude-haiku-4-5
# Model for vision tasks (photo-to-map): needs vision support
OPENROUTER_VISION_MODEL=anthropic/claude-haiku-4-5

# CORS — comma-separated list of allowed origins, or * for all
ALLOWED_ORIGINS=*

# Server
PORT=8000
WORKERS=1
LOG_LEVEL=info
